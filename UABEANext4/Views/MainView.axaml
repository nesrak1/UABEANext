<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:UABEANext4.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UABEANext4.Views.MainView"
             x:DataType="vm:MainViewModel"
             RenderOptions.BitmapInterpolationMode="MediumQuality">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto,*,22" Margin="4">
        <Menu Grid.Row="0" Padding="0,6">
            <MenuItem Header="{DynamicResource Menu.File}">
                <MenuItem
                    Header="{DynamicResource Menu.File.Open}" Command="{Binding FileOpen}"
                    HotKey="Ctrl+O" InputGesture="Ctrl+O" />
                <MenuItem
                    Header="{DynamicResource Menu.File.OpenFolder}" Command="{Binding FileOpenFolder}"
                    HotKey="Ctrl+Shift+O" InputGesture="Ctrl+Shift+O" />
                <MenuItem
                    Header="{DynamicResource Menu.File.Save}" Command="{Binding FileSave}"
                    HotKey="Ctrl+S" InputGesture="Ctrl+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{DynamicResource Menu.File.SaveAs}" Command="{Binding FileSaveAs}"
                    HotKey="Ctrl+Shift+S" InputGesture="Ctrl+Shift+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{DynamicResource Menu.File.SaveAll}" Command="{Binding FileSaveAll}"
                    HotKey="Ctrl+Alt+S" InputGesture="Ctrl+Alt+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{DynamicResource Menu.File.Close}" Command="{Binding FileCloseAll}"
                    HotKey="Ctrl+Shift+W" InputGesture="Ctrl+Shift+W" IsEnabled="{Binding Workspace.RootItems.Count}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.View}">
                <MenuItem Header="{DynamicResource Menu.View.DuplicateTab}" Command="{Binding ViewDuplicateTab}" />
                <MenuItem Header="-" />
                <MenuItem Header="{DynamicResource Menu.View.WorkspaceExplorer}" ToggleType="CheckBox" IsChecked="{Binding DockWorkspaceExplorerVisible, Mode=TwoWay}" />
                <MenuItem Header="{DynamicResource Menu.View.Hierarchy}" ToggleType="CheckBox" IsChecked="{Binding DockHierarchyVisible, Mode=TwoWay}" />
                <MenuItem Header="{DynamicResource Menu.View.Inspector}" ToggleType="CheckBox" IsChecked="{Binding DockInspectorVisible, Mode=TwoWay}" />
                <MenuItem Header="{DynamicResource Menu.View.Previewer}" ToggleType="CheckBox" IsChecked="{Binding DockPreviewerVisible, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Tools}">
                <MenuItem Header="{DynamicResource Menu.Tools.AssetInfo}" Command="{Binding ShowAssetInfoDialog}" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem Header="{DynamicResource Menu.Tools.SearchBytes}" Command="{Binding ShowSearchBytesDialog}" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem Header="{DynamicResource Menu.File.Settings}" Command="{Binding ShowOptionsDialog}" />
            </MenuItem>
        </Menu>
        <DockControl Layout="{Binding Layout}" Margin="4" Grid.Row="1" Name="dockControl" />
        <Grid ColumnDefinitions="1*,4,2*" Margin="4,0,0,4" Grid.Row="2">
            <ProgressBar Value="{Binding Workspace.ProgressValue}" Minimum="0" Maximum="1" Grid.Column="0" />
            <Label Content="{Binding Workspace.ProgressText}" Grid.Column="2" Padding="0" />
        </Grid>
    </Grid>
</UserControl>
