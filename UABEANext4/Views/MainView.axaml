<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:UABEANext4.ViewModels"
             xmlns:services="clr-namespace:UABEANext4.Services"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UABEANext4.Views.MainView"
             x:DataType="vm:MainViewModel"
             RenderOptions.BitmapInterpolationMode="MediumQuality">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto,*,22" Margin="4">
        <Menu Grid.Row="0" Padding="0,6">
            <MenuItem Header="{Binding [File], Source={x:Static services:LocalizationService.Instance}}">
                <MenuItem
                    Header="{Binding [Open], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding FileOpen}"
                    HotKey="Ctrl+O" InputGesture="Ctrl+O" />
                <MenuItem
                    Header="{Binding [OpenFolder], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding FileOpenFolder}"
                    HotKey="Ctrl+Shift+O" InputGesture="Ctrl+Shift+O" />
                <MenuItem
                    Header="{Binding [SaveSelected], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding FileSave}"
                    HotKey="Ctrl+S" InputGesture="Ctrl+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{Binding [SaveSelectedAs], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding FileSaveAs}"
                    HotKey="Ctrl+Shift+S" InputGesture="Ctrl+Shift+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{Binding [SaveAll], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding FileSaveAll}"
                    HotKey="Ctrl+Alt+S" InputGesture="Ctrl+Alt+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{Binding [CloseAll], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding FileCloseAll}"
                    HotKey="Ctrl+Shift+W" InputGesture="Ctrl+Shift+W" IsEnabled="{Binding Workspace.RootItems.Count}" />
            </MenuItem>
            <MenuItem Header="{Binding [View], Source={x:Static services:LocalizationService.Instance}}">
                <MenuItem Header="{Binding [DuplicateTab], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding ViewDuplicateTab}" />
                <MenuItem Header="-" />
                <MenuItem Header="{Binding [WorkspaceExplorer], Source={x:Static services:LocalizationService.Instance}}" ToggleType="CheckBox" IsChecked="{Binding DockWorkspaceExplorerVisible, Mode=TwoWay}" />
                <MenuItem Header="{Binding [Hierarchy], Source={x:Static services:LocalizationService.Instance}}" ToggleType="CheckBox" IsChecked="{Binding DockHierarchyVisible, Mode=TwoWay}" />
                <MenuItem Header="{Binding [Inspector], Source={x:Static services:LocalizationService.Instance}}" ToggleType="CheckBox" IsChecked="{Binding DockInspectorVisible, Mode=TwoWay}" />
                <MenuItem Header="{Binding [Previewer], Source={x:Static services:LocalizationService.Instance}}" ToggleType="CheckBox" IsChecked="{Binding DockPreviewerVisible, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Header="{Binding [Tools], Source={x:Static services:LocalizationService.Instance}}">
                <MenuItem Header="{Binding [AssetInfo], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding ShowAssetInfoDialog}" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem Header="{Binding [SearchBytes], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding ShowSearchBytesDialog}" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem Header="{Binding [Options], Source={x:Static services:LocalizationService.Instance}}" Command="{Binding ShowOptionsDialog}" />
            </MenuItem>
        </Menu>
        <DockControl Layout="{Binding Layout}" Margin="4" Grid.Row="1" Name="DockControl" />
        <Grid ColumnDefinitions="1*,4,2*" Margin="4,0,0,4" Grid.Row="2">
            <ProgressBar Value="{Binding Workspace.ProgressValue}" Minimum="0" Maximum="1" Grid.Column="0" />
            <Label Content="{Binding Workspace.ProgressText}" Grid.Column="2" Padding="0" />
        </Grid>
    </Grid>
</UserControl>
