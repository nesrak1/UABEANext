<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:UABEANext4.ViewModels"
             xmlns:lang="clr-namespace:UABEANext4.Assets.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UABEANext4.Views.MainView"
             x:DataType="vm:MainViewModel"
             RenderOptions.BitmapInterpolationMode="MediumQuality">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto,*,22" Margin="4">
        <Menu Grid.Row="0" Padding="0,6">
            <MenuItem Header="{x:Static lang:Localization.File}">
                <MenuItem
                    Header="{x:Static lang:Localization.Open}" Command="{Binding FileOpen}"
                    HotKey="Ctrl+O" InputGesture="Ctrl+O" />
                <MenuItem
                    Header="{x:Static lang:Localization.Open_Folder}" Command="{Binding FileOpenFolder}"
                    HotKey="Ctrl+Shift+O" InputGesture="Ctrl+Shift+O" />
                <MenuItem
                    Header="{x:Static lang:Localization.Save_Selected}" Command="{Binding FileSave}"
                    HotKey="Ctrl+S" InputGesture="Ctrl+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{x:Static lang:Localization.Save_Selected_As}" Command="{Binding FileSaveAs}"
                    HotKey="Ctrl+Shift+S" InputGesture="Ctrl+Shift+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{x:Static lang:Localization.Save_All}" Command="{Binding FileSaveAll}"
                    HotKey="Ctrl+Alt+S" InputGesture="Ctrl+Alt+S" IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem
                    Header="{x:Static lang:Localization.Close_All}" Command="{Binding FileCloseAll}"
                    HotKey="Ctrl+Shift+W" InputGesture="Ctrl+Shift+W" IsEnabled="{Binding Workspace.RootItems.Count}" />
            </MenuItem>
            <MenuItem Header="{x:Static lang:Localization.View}">
                <MenuItem Header="{x:Static lang:Localization.Duplicate_Tab}" Command="{Binding ViewDuplicateTab}" />
                <MenuItem Header="-" />
                <MenuItem Header="{x:Static lang:Localization.Workspace_Explorer}" ToggleType="CheckBox"
                          IsChecked="{Binding DockWorkspaceExplorerVisible, Mode=TwoWay}" />
                <MenuItem Header="{x:Static lang:Localization.Hierarchy}" ToggleType="CheckBox"
                          IsChecked="{Binding DockHierarchyVisible, Mode=TwoWay}" />
                <MenuItem Header="{x:Static lang:Localization.Inspector}" ToggleType="CheckBox"
                          IsChecked="{Binding DockInspectorVisible, Mode=TwoWay}" />
                <MenuItem Header="{x:Static lang:Localization.Previewer}" ToggleType="CheckBox"
                          IsChecked="{Binding DockPreviewerVisible, Mode=TwoWay}" />
            </MenuItem>
            <MenuItem Header="{x:Static lang:Localization.Tools}">
                <MenuItem Header="{x:Static lang:Localization.Asset_Info}" Command="{Binding ShowAssetInfoDialog}"
                          IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem Header="{x:Static lang:Localization.Search_Bytes}" Command="{Binding ShowSearchBytesDialog}"
                          IsEnabled="{Binding Workspace.RootItems.Count}" />
                <MenuItem Header="{x:Static lang:Localization.Options}" Command="{Binding ShowOptionsDialog}" />
            </MenuItem>
            <MenuItem Header="{x:Static lang:Localization.Languages}" Command="{Binding ShowLanguagesDialog}"></MenuItem>
        </Menu>
        <DockControl Layout="{Binding Layout}" Margin="4" Grid.Row="1" Name="dockControl" />
        <Grid ColumnDefinitions="1*,4,2*" Margin="4,0,0,4" Grid.Row="2">
            <ProgressBar Value="{Binding Workspace.ProgressValue}" Minimum="0" Maximum="1" Grid.Column="0" />
            <Label Content="{Binding Workspace.ProgressText}" Grid.Column="2" Padding="0" />
        </Grid>
    </Grid>
</UserControl>