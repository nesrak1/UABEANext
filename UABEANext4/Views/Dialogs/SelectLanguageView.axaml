<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dlg="using:UABEANext4.ViewModels.Dialogs"
             xmlns:cnf="using:UABEANext4.Logic.Configuration"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="650"
             x:Class="UABEANext4.Views.Dialogs.SelectLanguageView"
             x:DataType="dlg:SelectLanguageViewModel"
             Background="{DynamicResource DockThemeBackgroundBrush}">

    <StackPanel Margin="10" Width="50" HorizontalAlignment="Right" VerticalAlignment="Bottom">

        <Button>OK</Button>
    </StackPanel>

</UserControl>