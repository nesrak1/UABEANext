<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uac="using:UABEANext4.Converters"
             xmlns:uaw="using:UABEANext4.AssetWorkspace"
             xmlns:menu="using:UABEANext4.ViewModels.Menu"
             xmlns:tools="using:UABEANext4.ViewModels.Tools"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UABEANext4.Views.Tools.WorkspaceExplorerToolView"
             x:DataType="tools:WorkspaceExplorerToolViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="F2" Command="{Binding RenameItem}" />
    </UserControl.KeyBindings>

    <UserControl.Resources>
        <uac:WsItemColorConverter x:Key="WsItemColorConverter" />
        <uac:BitmapAssetValueConverter x:Key="BitmapAssetValueConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="*,26">
        <TreeView Margin="0,0,0,0" Background="{DynamicResource DockThemeListBackgroundBrush}" Name="SolutionTreeView"
                  ItemsSource="{Binding Workspace.RootItems}" SelectedItems="{Binding SelectedItems}"
                  SelectionMode="Multiple" Grid.Row="0">
            <TreeView.ItemTemplate>
                <TreeDataTemplate DataType="{x:Type uaw:WorkspaceItem}" ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}">
                        <TextBlock.Foreground>
                            <MultiBinding Converter="{StaticResource WsItemColorConverter}">
                                <Binding Path="ObjectType" />
                                <DynamicResource ResourceKey="DockThemeListBackgroundBrush" />
                            </MultiBinding>
                        </TextBlock.Foreground>
                    </TextBlock>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ContextFlyout>
                <MenuFlyout ItemsSource="{Binding ContextMenuItems}" Opening="MenuFlyout_Opening">
                    <MenuFlyout.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="menu:MenuOptionViewModel">
                            <Setter Property="Header" Value="{Binding Header}"/>
                            <Setter Property="Command" Value="{Binding Command}"/>
                            <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
                            <Setter Property="ItemsSource" Value="{Binding Items}"/>
                            <Setter Property="Icon">
                                <Template>
                                    <Image Source="{Binding IconPath, Converter={StaticResource BitmapAssetValueConverter}}" Width="16" Height="16" />
                                </Template>
                            </Setter>
                        </ControlTheme>
                    </MenuFlyout.ItemContainerTheme>
                </MenuFlyout>
            </TreeView.ContextFlyout>
        </TreeView>
        <Border Grid.Row="1"
                Background="{DynamicResource DockThemeBackgroundBrush}"
                BorderBrush="{DynamicResource DockThemeBorderLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                <Button Classes="footer-btn"
                        Command="{Binding LoadAll}"
                        IsEnabled="{Binding Workspace.RootItems.Count}"
                        ToolTip.Tip="Load all items">
                    <TextBlock>Load all</TextBlock>
                </Button>

                <Rectangle Width="1" Height="14" Fill="{DynamicResource DockThemeBorderLowBrush}" Margin="2,0" />

                <Button Classes="footer-btn"
                        Click="ExpandAll"
                        IsEnabled="{Binding Workspace.RootItems.Count}">
                    <TextBlock>Expand</TextBlock>
                </Button>

                <Button Classes="footer-btn"
                        Click="CollapseAll"
                        IsEnabled="{Binding Workspace.RootItems.Count}">
                    <TextBlock>Collapse</TextBlock>
                </Button>

                <Rectangle Width="1" Height="14" Fill="{DynamicResource DockThemeBorderLowBrush}" Margin="2,0" />

                <ToggleButton Classes="footer-btn"
                              IsChecked="{Binding SelectOpensFiles}"
                              IsEnabled="{Binding Workspace.RootItems.Count}">
                    <TextBlock>Auto load</TextBlock>
                </ToggleButton>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>