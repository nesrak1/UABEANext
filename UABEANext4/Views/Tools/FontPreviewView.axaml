<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:tools="using:UABEANext4.ViewModels.Tools"
             d:DesignWidth="600" d:DesignHeight="700"
             x:Class="UABEANext4.Views.Tools.FontPreviewView"
             x:DataType="tools:PreviewerToolViewModel">

    <Grid RowDefinitions="Auto, *">
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="12,12,12,8"
                    VerticalAlignment="Center">

            <TextBlock Text="Unicode Page:"
                       VerticalAlignment="Center" />

            <ComboBox Name="PageSelector"
                      ItemsSource="{Binding FontPreview.PageNames}"
                      SelectedIndex="{Binding FontPreview.CurrentPageIndex}"
                      Width="180"
                      MinHeight="32"/>

        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Image
                Source="{Binding FontPreview.Image}"
                Stretch="None"
                Margin="12" />
        </ScrollViewer>
    </Grid>
</UserControl>